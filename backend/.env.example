# This file documents the environment variables expected by the backend module.
# It exists so local setup and deployment configuration share the same contract.
# It fits the system by making future wallet, AI, storage and blockchain integrations explicit from the start.
NODE_ENV=development
PORT=4000
APP_NAME=TimeLend API
API_VERSION=v1
FRONTEND_APP_URL=http://localhost:3000
# Production Vercel value:
# FRONTEND_APP_URL=https://time-lend.vercel.app
# Transition-safe value while both frontend domains are live:
# FRONTEND_APP_URL=https://time-lend-frontend.vercel.app,https://time-lend.vercel.app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timelend
PRIVATE_KEY=
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
TIME_LEND_CONTRACT_ADDRESS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h
AUTH_CHALLENGE_TTL_MINUTES=15
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=change-me-in-production
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=5242880
AVALANCHE_CHAIN_ID=43113
INTERNAL_API_KEY=change-me-in-production
FAILED_FINALIZATION_INTERVAL_MS=30000
