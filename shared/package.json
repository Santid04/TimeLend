{
  "name": "@timelend/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Paquete compartido de TimeLend con tipos, DTOs, constantes, esquemas y placeholders de ABI para frontend y backend.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./abi/TimeLend.json": "./abi/TimeLend.json"
  },
  "files": [
    "abi",
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "clean": "pnpm exec rimraf dist"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}
