# This file documents the environment variables expected by the smart contract workspace.
# It exists to make local development and Avalanche Fuji deployment reproducible.
# It fits the system by providing one deployment contract for the definitive TimeLend on-chain layer.
HARDHAT_NETWORK=hardhat
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
RPC_URL=
DEPLOYER_PRIVATE_KEY=
INITIAL_OWNER_ADDRESS=
BACKEND_WALLET_ADDRESS=
APPEAL_WINDOW_SECONDS=86400
