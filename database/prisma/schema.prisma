// This file defines the initial Prisma data model for TimeLend.
// It exists to establish the first persistence contracts for users and commitments.
// It fits the system by giving the backend and future migrations a stable relational baseline.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This enum models the early commitment lifecycle states.
// It exists to keep status transitions typed from the database layer upward.
// It fits the system by preparing the schema for AI review, appeal and resolution flows.
enum CommitmentStatus {
  DRAFT
  ACTIVE
  EVIDENCE_PENDING
  UNDER_REVIEW
  COMPLETED
  FAILED
  APPEALED
}

// This model represents a platform user identified by wallet address.
// It exists to anchor ownership of commitments and future authentication records.
// It fits the system by acting as the root actor entity for the TimeLend domain.
model User {
  id            String       @id @default(cuid())
  walletAddress String       @unique
  displayName   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  commitments   Commitment[]
}

// This model stores the initial shape of a user commitment.
// It exists to persist the off-chain record that future blockchain and AI flows will reference.
// It fits the system by capturing the minimum task, amount and deadline data needed in later prompts.
model Commitment {
  id                   String           @id @default(cuid())
  userId               String
  title                String
  description          String?
  escrowAmount         Decimal          @db.Decimal(18, 8)
  deadlineAt           DateTime
  failureWalletAddress String
  evidenceReference    String?
  aiReviewSummary      String?
  appealUsed           Boolean          @default(false)
  status               CommitmentStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([deadlineAt])
  @@index([userId])
}
